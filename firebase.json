{
  "hosting": {
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "headers": [
      {
        "source": "/index.html",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-store, max-age=0, must-revalidate"
          }
        ]
      },
      {
        "source": "/assets/**",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=31536000, immutable"
          }
        ]
      }
    ],
    "rewrites": [
      {
        "source": "/zoho/**",
        "function": "zohoProxy"
      },
      {
        "source": "/api/tap/verify",
        "function": "tapVerificationHandler"
      },
      {
        "source": "/api/tap",
        "function": "tapPaymentHandler"
      },
      {
        "source": "/api/orderPreview",
        "function": "orderPreview"
      },
      {
        "source": "/api/**",
        "function": "orderHandler"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "functions": {
    "source": "functions"
  },
  "storage": {
    "rules": "storage.rules"
  }
}
