{
  "hosting": {
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/zoho/**",
        "function": "zohoProxy"
      },
      {
        "source": "/api/tap/verify",
        "function": "tapVerificationHandler"
      },
      {
        "source": "/api/tap",
        "function": "tapPaymentHandler"
      },
      {
        "source": "/api/**",
        "function": "orderHandler"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "functions": {
    "source": "functions"
  }
}