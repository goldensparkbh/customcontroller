rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Admin uploads + storefront images loaded via download URLs
    match /configurator/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /shop_items/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
