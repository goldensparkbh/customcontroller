# PostgreSQL
DATABASE_URL=postgresql://user:password@host:25060/database?sslmode=require

# Public root of the DigitalOcean Space/CDN containing the "migrated" folder.
# Do not include /migrated here; DO_SPACES_KEY_PREFIX adds it below.
MIGRATED_ASSETS_PUBLIC_BASE_URL=https://your-space.your-region.cdn.digitaloceanspaces.com
DO_SPACES_KEY_PREFIX=migrated

# DigitalOcean Spaces upload settings
DO_SPACES_ENDPOINT=https://your-region.digitaloceanspaces.com
DO_SPACES_BUCKET=your-space
DO_SPACES_KEY=your-access-key
DO_SPACES_SECRET=your-secret-key
