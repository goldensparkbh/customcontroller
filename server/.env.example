# PostgreSQL
DATABASE_URL=postgresql://user:password@host:25060/database?sslmode=require

# Public root containing the "migrated" folder. This CDN setup requires the
# Space name in both the hostname and path. Do not include /migrated here.
MIGRATED_ASSETS_PUBLIC_BASE_URL=https://customcontroller.fra1.cdn.digitaloceanspaces.com/customcontroller
DO_SPACES_KEY_PREFIX=migrated

# DigitalOcean Spaces upload settings
DO_SPACES_ENDPOINT=https://fra1.digitaloceanspaces.com
DO_SPACES_BUCKET=customcontroller
DO_SPACES_KEY=your-access-key
DO_SPACES_SECRET=your-secret-key
